# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_EMAIL=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# Elasticsearch
ELASTICSEARCH_URI=http://localhost:80

# MySQL
MYSQL_URL=jdbc:mysql://localhost:3306/your-database?useUnicode=true&serverTimezone=Asia/Seoul
MYSQL_PORT=3306
MYSQL_ROOT_USERNAME=root
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=your-database

# MongoDB
MONGO_URL=mongodb://localhost:27017/your-database
MONGO_DATABASE=your-database
MONGO_USERNAME=your-mongo-user
MONGO_PASSWORD=your-mongo-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_ERLANG_COOKIE=your-erlang-cookie
RABBITMQ_USERNAME=your-rabbitmq-user
RABBITMQ_PASSWORD=your-rabbitmq-password

# Storage
# local: run the project without AWS
# s3: use Amazon S3 + CloudFront for file upload
STORAGE_TYPE=local

# AWS
# These values are required when STORAGE_TYPE=s3.
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=ap-northeast-2
AWS_IAM_ACCESS_KEY=your-aws-access-key
AWS_IAM_SECRET_KEY=your-aws-secret-key
AWS_CLOUD_FRONT=your-cloudfront-domain

# JWT
ACCESS_KEY=your-access-token-secret
REFRESH_KEY=your-refresh-token-secret

# Debezium
DEBEZIUM_USER=your-debezium-user
DEBEZIUM_PASSWORD=your-debezium-password
DEBEZIUM_SOURCE_DATABASE_SERVER_ID=12345

# Grafana
GRAFANA_SECURITY_ADMIN_USER=your-grafana-admin-user
GRAFANA_SECURITY_ADMIN_PASSWORD=your-grafana-admin-password