{
  "settings": {
    "index": {
      "max_ngram_diff": 6
    },
    "analysis": {
      "char_filter": {
        "remove_space": {
          "type": "pattern_replace",
          "pattern": "\\s+",
          "replacement": ""
        }
      },
      "filter": {
        "edge_1_7": {
          "type": "edge_ngram",
          "min_gram": 1,
          "max_gram": 7
        },
        "ngram_2_7": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 7
        },
        "lowercase": {
          "type": "lowercase"
        }
      },
      "analyzer": {
        "member_prefix": {
          "type": "custom",
          "char_filter": [
            "remove_space"
          ],
          "tokenizer": "keyword",
          "filter": [
            "lowercase",
            "edge_1_7"
          ]
        },
        "member_prefix_search": {
          "type": "custom",
          "char_filter": [
            "remove_space"
          ],
          "tokenizer": "keyword",
          "filter": [
            "lowercase"
          ]
        },
        "member_contains": {
          "type": "custom",
          "char_filter": [
            "remove_space"
          ],
          "tokenizer": "keyword",
          "filter": [
            "lowercase",
            "ngram_2_7"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "memberId": {
        "type": "keyword"
      },
      "memberName": {
        "type": "keyword",
        "fields": {
          "prefix": {
            "type": "text",
            "analyzer": "member_prefix",
            "search_analyzer": "member_prefix_search"
          },
          "contains": {
            "type": "text",
            "analyzer": "member_contains"
          },
          "fuzzy": {
            "type": "text",
            "analyzer": "member_prefix_search"
          }
        }
      },
      "memberImageUrl": {
        "type": "keyword"
      }
    }
  }
}
